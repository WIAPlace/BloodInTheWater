  m_Script: {fileID: 11500000, guid: e98051a6c4ccd6a4a90a180c0343c7b9, type: 3}
  m_Name: Hints_FishingRod
  m_EditorClassIdentifier: 
  speaker: []
  dialogue:
  - Hold [Left Click / RT] to wind up your fishing rod and release by letting it
    go.
  - Try not to hit the bobber too close to the fish, it will scare it off.
  - You can reel in your fishing rod by holding [Left Click / RT]
  - When a fish notices your lure it will start this bobbing motion, soon it will
    go for your reel.
  - 'Press [Left Click / RT] when you hear the line go slack to begin the fish catching
    game. '
  - You will only have so long before it will get away so be sure to be ready.
  - Its on the line, now press [Left Click / RT] to start reeling it in.
  audioclip: []
